{
  "name": "cert-manager.io",
  "version": "2.0.0",
  "license": "Apache-2.0",
  "author": "cert-manager-maintainers",
  "contributors": [
    {
      "name": "cert-manager-maintainers",
      "email": "cert-manager-maintainers@googlegroups.com",
      "url": "https://cert-manager.io"
    }
  ],
  "engines": {
    "npm": ">=11.0.0",
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "postbuild": "npm run generate:sitemap",
    "generate:sitemap": "next-sitemap",
    "start": "next start",
    "check": "concurrently --group --timings npm:check:* # Run all the npm check:* scripts in parallel",
    "check:eslint": "eslint .",
    "check:stylelint": "stylelint **/*.css",
    "check:links": "find content/docs -type f -name '*.md' | xargs markdown-link-check --quiet --config markdown-link-check.json 2>&1 | awk -v RS=FILE: '/ERROR/{f=1; print RS $0} END{exit f}' # Split into records based on the word FILE and print only records containing word ERROR",
    "check:spelling": "cspell lint --no-progress --no-must-find-files 'content/docs/**/*.md' 'content/docs/**/*.html' 'content/announcements/**/*.md' 'content/pages/**/*.md'",
    "check:markdown": "remark --rc-path .remarkrc --frail --quiet content/"
  },
  "lint-staged": {
    "*.{css}": [
      "stylelint --fix"
    ],
    "*.{js,json,jsx,md,mdx}": [
      "prettier --write"
    ],
    "*.{js,jsx,md,mdx}": [
      "eslint --cache --fix"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "browser": {
    "fs": false,
    "path": false,
    "child_process": false
  },
  "dependencies": {
    "@docsearch/react": "4.6.2",
    "@headlessui/react": "2.2.10",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.4",
    "classnames": "2.5.1",
    "compare-versions": "6.1.1",
    "copy-to-clipboard": "^3.3.3",
    "gray-matter": "4.0.3",
    "lodash": "^4.17.23",
    "next": "^16.0.0",
    "next-mdx-remote": "6.0.0",
    "next-seo": "6.8.0",
    "prism-react-renderer": "2.4.1",
    "prismjs": "^1.30.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-scroll": "1.9.3",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "rehype-slug": "6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "4.0.1",
    "remark-inline-links": "7.0.0",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "4.2.3",
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.4",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "concurrently": "9.2.1",
    "cspell": "10.0.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-mdx": "3.7.0",
    "format-api-docs": "file:scripts/gendocs/postprocess",
    "globals": "17.5.0",
    "markdown-link-check": "3.14.2",
    "next-sitemap": "4.2.3",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "remark-cli": "12.0.1",
    "remark-code-import": "1.2.0",
    "remark-lint": "10.0.1",
    "remark-preset-lint-consistent": "6.0.1",
    "remark-preset-lint-recommended": "7.0.1",
    "remark-toc": "9.0.0",
    "stylelint": "17.8.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.2.2"
  }
}
